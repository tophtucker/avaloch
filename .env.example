# Copy to `.env` for local manual runs (`npm run enrich-places`), and set the
# same values in Vercel Project Settings -> Environment Variables for the cron.

# Sanity API token with write access (Editor/Write).
# Create at https://www.sanity.io/manage/project/lxtjf1cx/api -> Tokens
SANITY_WRITE_TOKEN=

# Google Maps Platform API key with the "Places API (New)" enabled.
# https://console.cloud.google.com/google/maps-apis/
GOOGLE_MAPS_API_KEY=

# Shared secret for the cron endpoint. Vercel automatically sends this as
# `Authorization: Bearer <CRON_SECRET>` on scheduled invocations.
CRON_SECRET=

# Optional overrides (defaults shown):
# SANITY_PROJECT_ID=lxtjf1cx
# SANITY_DATASET=prod
